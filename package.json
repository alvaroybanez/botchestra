{
  "name": "botchestra",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently --names web,convex \"bun run --filter @botchestra/web dev\" \"bunx convex dev\"",
    "build": "bun run --filter '*' build",
    "test": "vitest run",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.34.0",
    "convex-helpers": "^0.1.114",
    "convex-test": "^0.0.43",
    "zod": "^3.25.76"
  }
}
